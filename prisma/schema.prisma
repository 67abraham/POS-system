// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url = env("DATABASE_URL")
}

enum Role{
	ADMIN
	MANAGER
	CUSTOMER
	STAFF
	KITCHEN
}

model User {
	id            String    @id @default(auto()) @map("_id") @db.ObjectId
	name          String?
	email         String    @unique
	emailVerified Boolean
	image         String?
	role Role @default(CUSTOMER)
	phone		String?
	dateOfBirth	DateTime?
	biography Json?
	createdAt     DateTime  @default(now())
	updatedAt     DateTime  @updatedAt
	// Relations
	sessions Session[]
	accounts Account[]
	feedback Feedback[]
	order Order[]
	@@map("user")
}
model Session {
	id           String   @id @default(auto()) @map("_id") @db.ObjectId
	userId       String   @db.ObjectId
	token        String   @unique
	expiresAt    DateTime
	ipAddress    String?
	userAgent    String?
	createdAt    DateTime @default(now())
	updatedAt    DateTime @updatedAt
	// Relations
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
	@@map("session")
}
model Account {
	id                   String    @id @default(auto()) @map("_id") @db.ObjectId
	userId               String    @db.ObjectId
	accountId            String
	providerId           String
	accessToken          String?
	refreshToken         String?
	accessTokenExpiresAt DateTime?
	refreshTokenExpiresAt DateTime?
	scope                String?
	idToken              String?
	password             String?
	createdAt            DateTime  @default(now())
	updatedAt            DateTime  @updatedAt
	// Relations
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
	@@map("account")
}
model Verification {
	id         String   @id @default(auto()) @map("_id") @db.ObjectId
	identifier String
	value      String
	expiresAt  DateTime
	createdAt  DateTime @default(now())
	updatedAt  DateTime @updatedAt
	@@map("verification")
}

model Menu{
	id String @id @default(auto()) @map("_id") @db.ObjectId
	menuName String @unique
	slung String
	createAt DateTime @default(now())

	menuItem MenuItem[]
}

model ActivityLog{
	id String @id @default(auto()) @map("_id") @db.ObjectId
	userId String @db.ObjectId 
	details String
	actions String
	createAt DateTime @default(now())

}


model MenuItem{
	id String @id @default(auto()) @map("_id") @db.ObjectId
	name String
	discount Float? @default(0)
	price Float @default(0)
	description Json
	image String
	isAvailable Boolean @default(true)
	menuId String  @db.ObjectId
	aiSuggestion String?

	//relation 
	feedback Feedback[]
	menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
	order Order[]
	createAt DateTime @default(now())
}

model Feedback{
	id String @id @default(auto()) @map("_id") @db.ObjectId
	userName String
	userImage String
	rating Int @default(0)
	userId String @db.ObjectId
	commitment Json
	createAt DateTime @default(now())
	menuItemId String @db.ObjectId


	//relation 
	menu MenuItem @relation(fields: [menuItemId], references: [id])
	user User @relation(fields: [userId], references: [id])

}

enum OrderStatus{
	PREPARING
	CANCELLED
	DELIVERED
}

model Order{
	id String @id @default(auto()) @map("_id") @db.ObjectId
	userName String
	status OrderStatus @default(PREPARING)
	menuItemId String @db.ObjectId
	tableId String @db.ObjectId
	userId String @db.ObjectId
	paymentID String?
	createAt DateTime @default(now())

	//relation 
	user User @relation(fields: [userId], references: [id])
	menuItem MenuItem @relation(fields: [menuItemId], references: [id])
	table Table @relation(fields: [tableId], references: [id])



}

enum TableStatus{
	OCCUPIED
	AVAILABLE
	RESERVED
}
model Table{
	id String @id @default(auto()) @map("_id") @db.ObjectId
	tableName String @unique
	seats Int
	tableStatus TableStatus @default(AVAILABLE)
	image String
	createAt DateTime @default(now())
	

	order Order[]

}

enum ResStatus{
	PENDING
	CONFIRM
}

model Reservation{
	id String @id @default(auto()) @map("_id") @db.ObjectId
	date DateTime
	userName String
	status ResStatus @default(PENDING)
	userId String @db.ObjectId
	tableId String @db.ObjectId


}